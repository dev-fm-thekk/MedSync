# MetaMask / Web3 Configuration
NEXT_PUBLIC_METAMASK_ENABLED=true

# Backend API Configuration
# This is the only place you need to change the host/port
# All API endpoints are relative to this base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# For production/staging:
# NEXT_PUBLIC_API_BASE_URL=https://api.medvault.com
# NEXT_PUBLIC_API_BASE_URL=https://staging-api.medvault.com

# Additional backend configuration
NEXT_PUBLIC_MEDIVAULT_SC_ADDRESS=0x...

# n8n RAG – chat webhook (POST { question } → { answer }) and upload-pdf (POST multipart PDF)
# NEXT_PUBLIC_N8N_RAG_WEBHOOK_URL=https://your-n8n.com/webhook/chat
# NEXT_PUBLIC_N8N_RAG_UPLOAD_PDF_URL=https://your-n8n.com/webhook/upload-pdf

# Alchemy NFT API (optional) – used to fetch owned NFTs on Sepolia instead of on-chain calls
# Get a key at https://dashboard.alchemy.com (create app → Sepolia)
# NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key
